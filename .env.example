# Firebase (from Firebase Console → Project settings → Your apps → Web app config)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Plaid (from Plaid Dashboard → Keys)
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
PLAID_PRODUCTS=transactions,investments
PLAID_REDIRECT_URI=https://localhost:5173/app
# PLAID_ENV options: sandbox | development | production
# sandbox   → fake data, no real banks
# development → real banks, up to 100 live Items (free testing)
# production → real banks, unlimited Items (requires Plaid approval)
# PLAID_PRODUCTS: comma-separated Plaid products to request consent for
# PLAID_REDIRECT_URI must match an Allowed redirect URI in your Plaid Dashboard.
# Required for OAuth-based banks (Chase, Capital One, etc.)
# Local: https://localhost:5173/app
# Production: must be HTTPS (e.g. https://yourdomain.com/app). Plaid rejects HTTP in production.

# Firebase Admin: path to service account JSON, or set FIREBASE_SERVICE_ACCOUNT to the JSON string directly (for Railway/cloud)
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# Postgres
DATABASE_URL=postgresql://user:password@host:5432/dbname

# CORS origin (default https://localhost:5173 for local dev)
CORS_ORIGIN=https://localhost:5173

# Backend API URL for the frontend (leave empty in production when same-origin)
VITE_API_URL=http://localhost:3001
